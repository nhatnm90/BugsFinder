<Window x:Class="MineSweeper.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MineSweeper.ViewModels"
        xmlns:conv="clr-namespace:MineSweeper.Converters"
        mc:Ignorable="d"
        Title="MineSweeper"
        ResizeMode="CanMinimize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBg}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:NumberToColorConverter x:Key="NumberToColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             CELL CONTROL TEMPLATE  — flat tile, single Border element
             Trigger order (last wins on same property):
               1. IsRevealed     → revealed bg + subtle border
               2. IsMineRevealed → mine bg (overrides IsRevealed bg)
               3. IsMouseOver    → hover highlight (only fires on enabled cells)
               4. IsPressed      → deeper press tint
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <ControlTemplate x:Key="CellControlTemplate" TargetType="Button">
            <Border x:Name="CellBorder"
                    Background="{DynamicResource CellBg}"
                    CornerRadius="5"
                    BorderThickness="0"
                    SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                    <Setter TargetName="CellBorder" Property="Background"      Value="{DynamicResource CellRevealedBg}"/>
                    <Setter TargetName="CellBorder" Property="BorderBrush"     Value="{DynamicResource CellBorder}"/>
                    <Setter TargetName="CellBorder" Property="BorderThickness" Value="1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMineRevealed}" Value="True">
                    <Setter TargetName="CellBorder" Property="Background"  Value="{DynamicResource MineBg}"/>
                    <Setter TargetName="CellBorder" Property="BorderBrush" Value="{DynamicResource MineBorder}"/>
                </DataTrigger>
                <!-- Decorative island marker — blue dot, never interactive -->
                <DataTrigger Binding="{Binding IsDecorative}" Value="True">
                    <Setter TargetName="CellBorder" Property="Background"   Value="#4A90D9"/>
                    <Setter TargetName="CellBorder" Property="Opacity"      Value="0.60"/>
                    <Setter TargetName="CellBorder" Property="CornerRadius" Value="10"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="CellBorder" Property="Background" Value="{DynamicResource CellHoverBg}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="CellBorder" Property="Background" Value="{DynamicResource CellPressedBg}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             CELL BUTTON STYLE
             Inactive cells (outside country border) are hidden but keep
             their space in the UniformGrid so the shape is preserved.
             Width / Height / Margin / FontSize are bound per-button in the
             DataTemplate so they update when switching between modes.
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <Style x:Key="CellButtonStyle" TargetType="Button">
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="IsEnabled"  Value="{Binding IsEnabled}"/>
            <Setter Property="Foreground"
                    Value="{Binding AdjacentMineCount,
                            Converter={StaticResource NumberToColorConverter}}"/>
            <Setter Property="Template"   Value="{StaticResource CellControlTemplate}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="False">
                    <Setter Property="Visibility" Value="Hidden"/>
                    <Setter Property="IsEnabled"  Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             RESET BUTTON STYLE — circular, emoji, color-coded by game state
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <Style x:Key="ResetButtonStyle" TargetType="Button">
            <Setter Property="Width"      Value="48"/>
            <Setter Property="Height"     Value="48"/>
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
            <Setter Property="FontSize"   Value="22"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ResetBorder"
                                Background="{DynamicResource ResetBg}"
                                CornerRadius="24"
                                BorderThickness="2"
                                BorderBrush="{DynamicResource ResetBorder}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding StatusEmoji}" Value="😎">
                                <Setter TargetName="ResetBorder" Property="Background"  Value="{DynamicResource WinBg}"/>
                                <Setter TargetName="ResetBorder" Property="BorderBrush" Value="{DynamicResource WinBorder}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusEmoji}" Value="😵">
                                <Setter TargetName="ResetBorder" Property="Background"  Value="{DynamicResource LossBg}"/>
                                <Setter TargetName="ResetBorder" Property="BorderBrush" Value="{DynamicResource LossBorder}"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ResetBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ResetBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             DIFFICULTY / THEME CHIP STYLE — pill-shaped, accent when selected
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <Style x:Key="DiffChipStyle" TargetType="Button">
            <Setter Property="Margin"     Value="4,0"/>
            <Setter Property="Padding"    Value="22,9"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChipBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource ChipBorder}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ChipContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource ChipFg}"
                                              TextElement.FontWeight="Normal"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipBorder"  Property="Background"            Value="{DynamicResource ChipHoverBg}"/>
                                <Setter TargetName="ChipContent" Property="TextElement.Foreground" Value="{DynamicResource ChipHoverFg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChipBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Smaller variant for the top control strip -->
        <Style x:Key="SmallChipStyle" TargetType="Button" BasedOn="{StaticResource DiffChipStyle}">
            <Setter Property="Padding"  Value="16,7"/>
            <Setter Property="Margin"   Value="3,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             THIN SCROLL BAR — 6 px wide, no arrows, rounded thumb
             Applied inside the board ScrollViewer via local Resources override.
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <Style x:Key="ThinScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="MinWidth"   Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Margin="0,4">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBg"
                                                        Background="{DynamicResource ChipBorder}"
                                                        CornerRadius="3"
                                                        Opacity="0.45"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBg" Property="Opacity"     Value="0.75"/>
                                                        <Setter TargetName="ThumbBg" Property="Background"  Value="{DynamicResource ChipHoverFg}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbBg" Property="Opacity"     Value="1"/>
                                                        <Setter TargetName="ThumbBg" Property="Background"  Value="{DynamicResource ChipSelectedBg}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             TUTORIAL BUTTON STYLES
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->

        <!-- Primary: accent filled pill — "Next →" / "Start! 🚀" -->
        <Style x:Key="TutPrimaryStyle" TargetType="Button">
            <Setter Property="Padding"    Value="18,8"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{DynamicResource TutPrimaryBg}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource TutPrimaryFg}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary: subtle pill — "← Back" -->
        <Style x:Key="TutSecondaryStyle" TargetType="Button">
            <Setter Property="Padding"    Value="14,8"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{DynamicResource TutSecondaryBg}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource TutSecondaryFg}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Skip: ghost / text-only — "Skip" -->
        <Style x:Key="TutSkipStyle" TargetType="Button">
            <Setter Property="Padding"    Value="8,8"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource TutSkipFg}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{DynamicResource TutSkipHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             TOOLTIP STYLE — themed to match the app card look
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <Style TargetType="ToolTip">
            <Setter Property="Background"   Value="{DynamicResource CardBg}"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource ChipBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="12,9"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="12"/>
        </Style>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             QUIZ OPTION BUTTON STYLE — wide answer-choice pill
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <Style x:Key="QuizOptionStyle" TargetType="Button">
            <Setter Property="Padding"    Value="14,10"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B"
                                Background="{DynamicResource AppBg}"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource ChipBorder}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource TextPrimary}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background"  Value="{DynamicResource ChipHoverBg}"/>
                                <Setter TargetName="B" Property="BorderBrush" Value="{DynamicResource ChipHoverFg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             QUIZ OPTION — CORRECT / WRONG HIGHLIGHT TEMPLATES
             Swapped in via DataTrigger per button once an answer is chosen.
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <ControlTemplate x:Key="QuizOptionCorrectTemplate" TargetType="Button">
            <Border Background="#2E7D32" CornerRadius="8"
                    BorderBrush="#43A047" BorderThickness="1"
                    Padding="14,10">
                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                  TextElement.Foreground="White"
                                  TextElement.FontWeight="SemiBold"/>
            </Border>
        </ControlTemplate>

        <ControlTemplate x:Key="QuizOptionWrongTemplate" TargetType="Button">
            <Border Background="#B71C1C" CornerRadius="8"
                    BorderBrush="#EF5350" BorderThickness="1"
                    Padding="14,10">
                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"
                                  TextElement.Foreground="White"
                                  TextElement.FontWeight="SemiBold"/>
            </Border>
        </ControlTemplate>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             MINIMIZE BUTTON STYLE — circular —, neutral hover
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <Style x:Key="MinimizeButtonStyle" TargetType="Button">
            <Setter Property="Width"      Value="36"/>
            <Setter Property="Height"     Value="36"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MinBorder"
                                Background="{DynamicResource CardBg}"
                                CornerRadius="18"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ChipBorder}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource TextSecondary}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MinBorder" Property="Background"  Value="{DynamicResource ChipHoverBg}"/>
                                <Setter TargetName="MinBorder" Property="BorderBrush" Value="{DynamicResource ChipActiveBorder}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MinBorder" Property="Background" Value="{DynamicResource ChipActiveBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
             CLOSE BUTTON STYLE — circular ✕, turns red on hover
        ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width"      Value="36"/>
            <Setter Property="Height"     Value="36"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseBorder"
                                Background="{DynamicResource CardBg}"
                                CornerRadius="18"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ChipBorder}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{DynamicResource TextSecondary}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseBorder" Property="Background"   Value="#CC2222"/>
                                <Setter TargetName="CloseBorder" Property="BorderBrush"  Value="#FF4444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseBorder" Property="Background" Value="#991111"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════════════
         ROOT GRID — game content + tutorial overlay share the same cell
    ══════════════════════════════════════════════════════════════════════════ -->
    <Grid x:Name="RootGrid" Background="{DynamicResource AppBg}">

        <!-- ── Main game content ──────────────────────────────────────────── -->
        <!-- DataTrigger centres the content when fullscreen so the game card
             floats in the middle of the maximised window. -->
        <Border x:Name="GameContent" Padding="20,16">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFullScreen}" Value="True">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment"   Value="Center"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel Orientation="Vertical">

                <!-- ── Top controls strip: themes (left) + fullscreen (right) ── -->
                <Grid Margin="0,0,0,10">

                    <!-- Theme chips -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">

                        <!-- Dark theme -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Dark">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SmallChipStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" Padding="16,7">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                              TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                              TextElement.FontWeight="SemiBold"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="🌑 Dark" FontSize="11"/>
                        </Button>

                        <!-- Light theme -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Light">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SmallChipStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLightTheme}" Value="True">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" Padding="16,7">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                              TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                              TextElement.FontWeight="SemiBold"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="☀ Light" FontSize="11"/>
                        </Button>

                        <!-- Blue theme -->
                        <Button Command="{Binding ChangeThemeCommand}" CommandParameter="Blue">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SmallChipStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBlueTheme}" Value="True">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" Padding="16,7">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                              TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                              TextElement.FontWeight="SemiBold"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="🌊 Blue" FontSize="11"/>
                        </Button>

                    </StackPanel>

                    <!-- Right-side controls: leaderboard + extreme -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">

                    <!-- Leaderboard browser button -->
                    <Button x:Name="LeaderboardBtn"
                            Command="{Binding OpenLeaderboardBrowserCommand}"
                            Style="{StaticResource SmallChipStyle}"
                            Margin="0,0,6,0">
                        <TextBlock Text="🏆" FontSize="13"/>
                    </Button>

                    <!-- Extreme mode toggle button -->
                    <Button x:Name="ExtremeBtn"
                            Command="{Binding ToggleExtremeModeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SmallChipStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExtremeMode}" Value="True">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" Padding="16,7">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                          TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                          TextElement.FontWeight="SemiBold"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="{Binding ExtremeButtonText}" FontSize="11"/>
                    </Button>

                    </StackPanel><!-- end right-side controls -->

                </Grid>

                <!-- ── App title ──────────────────────────────────────────── -->
                <TextBlock Text="BUGS FINDER"
                           FontFamily="Segoe UI"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TitleFg}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>

                <!-- ══════════════════════════════════════════════════════════
                     HEADER CARD — mine counter | reset button | timer
                ══════════════════════════════════════════════════════════════ -->
                <Border x:Name="HeaderCard"
                        Background="{DynamicResource CardBg}"
                        CornerRadius="12"
                        Padding="20,12"
                        Margin="0,0,0,8">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.4"
                                          BlurRadius="12" ShadowDepth="2"
                                          Direction="270"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Bug counter + star count (left) -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                            <!-- Bug counter -->
                            <TextBlock Text="🐞"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="20"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding MineCounterDisplay}"
                                       FontFamily="Segoe UI"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource LcdFg}"
                                       VerticalAlignment="Center"/>

                            <!-- Separator -->
                            <Border Width="1"
                                    Background="{DynamicResource ChipBorder}"
                                    Margin="10,4,10,4"/>

                            <!-- Star count with bounce animation target -->
                            <StackPanel x:Name="StarPanel"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <StackPanel.RenderTransform>
                                    <ScaleTransform x:Name="StarScaleTransform" CenterX="24" CenterY="14"/>
                                </StackPanel.RenderTransform>
                                <TextBlock Text="⭐"
                                           FontFamily="Segoe UI Emoji"
                                           FontSize="20"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding Stars}"
                                           FontFamily="Segoe UI"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource LcdFg}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Reset emoji button (centre) -->
                        <Button x:Name="ResetBtn"
                                Grid.Column="1"
                                Style="{StaticResource ResetButtonStyle}"
                                Content="{Binding StatusEmoji}"
                                Command="{Binding NewGameCommand}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        <!-- Timer (right) — turns red during a challenge countdown -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding TimerDisplay}"
                                       FontFamily="Segoe UI"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource LcdFg}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInChallenge}" Value="True">
                                                <Setter Property="Foreground" Value="#FF3333"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="⏱"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="20"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInChallenge}" Value="True">
                                                <Setter Property="Foreground" Value="#FF3333"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════════════
                     BOARD CARD — card wrapping the cell grid
                ══════════════════════════════════════════════════════════════ -->
                <Border x:Name="BoardCard"
                        Background="{DynamicResource CardBg}"
                        CornerRadius="18"
                        Padding="8"
                        Margin="0,0,0,8">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.5"
                                          BlurRadius="16" ShadowDepth="4"
                                          Direction="270"/>
                    </Border.Effect>

                    <!-- ScrollViewer caps height for tall Special maps so the window
                         never overflows the screen. Standard boards have an infinite
                         MaxHeight so SizeToContent still works as before. -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="{Binding BoardMaxHeight}"
                                  CanContentScroll="False"
                                  Focusable="False">
                        <ScrollViewer.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ThinScrollBarStyle}"/>
                        </ScrollViewer.Resources>
                        <ItemsControl x:Name="GameBoard" ItemsSource="{Binding Cells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid
                                        Rows="{Binding DataContext.Rows,    ElementName=GameBoard}"
                                        Columns="{Binding DataContext.Cols, ElementName=GameBoard}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Width/Height/Margin/FontSize bound via ElementName so they
                                         update automatically when switching between modes. -->
                                    <Button Style="{StaticResource CellButtonStyle}"
                                            Width=   "{Binding DataContext.CellSize,     ElementName=GameBoard}"
                                            Height=  "{Binding DataContext.CellSize,     ElementName=GameBoard}"
                                            Margin=  "{Binding DataContext.CellMargin,   ElementName=GameBoard}"
                                            FontSize="{Binding DataContext.CellFontSize, ElementName=GameBoard}"
                                            Content="{Binding DisplayText}"
                                            Command="{Binding RevealCommand}">
                                        <Button.InputBindings>
                                            <MouseBinding MouseAction="RightClick"
                                                          Command="{Binding FlagCommand}"/>
                                        </Button.InputBindings>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- ══════════════════════════════════════════════════════════
                     DIFFICULTY CHIPS — pill-shaped selector
                ══════════════════════════════════════════════════════════════ -->
                <StackPanel x:Name="DiffBar"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,2,0,0">

                    <!-- Easy -->
                    <Button Command="{Binding ChangeDifficultyCommand}" CommandParameter="Easy">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DiffChipStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEasySelected}" Value="True">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" BorderThickness="0" Padding="22,9">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                          TextElement.FontWeight="SemiBold"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Easy" FontSize="12"/>
                    </Button>

                    <!-- Medium -->
                    <Button Command="{Binding ChangeDifficultyCommand}" CommandParameter="Medium">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DiffChipStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMediumSelected}" Value="True">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" BorderThickness="0" Padding="22,9">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                          TextElement.FontWeight="SemiBold"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Medium" FontSize="12"/>
                    </Button>

                    <!-- Hard (locked until 10 ⭐) -->
                    <Button Command="{Binding ChangeDifficultyCommand}" CommandParameter="Hard"
                            ToolTip="{Binding HardChipTooltip}"
                            ToolTipService.ShowDuration="9000">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DiffChipStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHardUnlocked}" Value="False">
                                        <Setter Property="Opacity" Value="0.55"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsHardSelected}" Value="True">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" BorderThickness="0" Padding="22,9">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                          TextElement.FontWeight="SemiBold"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="{Binding HardChipLabel}" FontSize="12"/>
                    </Button>

                    <!-- Special (country-shaped maps, locked until 15 ⭐) -->
                    <Button Command="{Binding ChangeDifficultyCommand}" CommandParameter="Special"
                            ToolTip="{Binding SpecialChipTooltip}"
                            ToolTipService.ShowDuration="9000">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DiffChipStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSpecialUnlocked}" Value="False">
                                        <Setter Property="Opacity" Value="0.55"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSpecialSelected}" Value="True">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{DynamicResource SpecialChipSelectedBg}" CornerRadius="8" BorderThickness="0" Padding="22,9">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"
                                                                          TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                          TextElement.FontWeight="SemiBold"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="{Binding SpecialChipLabel}" FontSize="12"/>
                    </Button>

                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             TUTORIAL OVERLAY — 4-curtain spotlight + description card
             Canvas children are positioned by code-behind after layout.
             IsHitTestVisible=True so curtain areas eat mouse events.
        ══════════════════════════════════════════════════════════════════════ -->
        <Canvas x:Name="TutorialOverlay"
                IsHitTestVisible="True"
                Visibility="{Binding Tutorial.IsVisible, Converter={StaticResource BoolToVis}}">

            <!-- ── 4 dimming rectangles that surround the spotlight ────────── -->
            <Rectangle x:Name="CurtainTop"
                       Fill="{DynamicResource CurtainColor}"
                       IsHitTestVisible="True"/>
            <Rectangle x:Name="CurtainLeft"
                       Fill="{DynamicResource CurtainColor}"
                       IsHitTestVisible="True"/>
            <Rectangle x:Name="CurtainRight"
                       Fill="{DynamicResource CurtainColor}"
                       IsHitTestVisible="True"/>
            <Rectangle x:Name="CurtainBottom"
                       Fill="{DynamicResource CurtainColor}"
                       IsHitTestVisible="True"/>

            <!-- ── Spotlight blocker — transparent, eats clicks inside spotlight ── -->
            <Rectangle x:Name="SpotlightBlocker"
                       Fill="Transparent"
                       IsHitTestVisible="True"/>

            <!-- ── Description card ────────────────────────────────────────── -->
            <Border x:Name="TutorialCard"
                    Width="300"
                    Background="{DynamicResource CardBg}"
                    CornerRadius="14"
                    Padding="20,16"
                    DataContext="{Binding Tutorial}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.7"
                                      BlurRadius="24" ShadowDepth="6"
                                      Direction="270"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Progress indicator -->
                    <TextBlock Text="{Binding StepProgress}"
                               FontFamily="Segoe UI"
                               FontSize="10"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,6"/>

                    <!-- Step title -->
                    <TextBlock Text="{Binding StepTitle}"
                               FontFamily="Segoe UI"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <!-- Step description -->
                    <TextBlock Text="{Binding StepDescription}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"
                               LineHeight="18"
                               Margin="0,0,0,18"/>

                    <!-- Navigation row: [Skip]  ...  [← Back] [Next →] -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Skip (ghost, left-aligned) -->
                        <Button Grid.Column="0"
                                Content="Skip"
                                Command="{Binding SkipCommand}"
                                Style="{StaticResource TutSkipStyle}"
                                Visibility="{Binding CanSkip, Converter={StaticResource BoolToVis}}"/>

                        <!-- Back (secondary, right cluster) -->
                        <Button Grid.Column="2"
                                Content="← Back"
                                Command="{Binding PrevCommand}"
                                Style="{StaticResource TutSecondaryStyle}"
                                Visibility="{Binding CanGoPrev, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,8,0"/>

                        <!-- Next / Start (primary) -->
                        <Button Grid.Column="3"
                                Content="{Binding NextButtonText}"
                                Command="{Binding NextCommand}"
                                Style="{StaticResource TutPrimaryStyle}"/>
                    </Grid>

                </StackPanel>
            </Border>

        </Canvas>

        <!-- ══════════════════════════════════════════════════════════════════
             RESULT POPUP — win / loss notification card
             Appears centred over a dim backdrop after every game ends.
             Dismissed by "Play Again" (starts new game) or "×" (close only).
        ══════════════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsResultVisible, Converter={StaticResource BoolToVis}}">

            <!-- Semi-transparent backdrop — eats clicks so the board is inactive -->
            <Rectangle Fill="{DynamicResource CurtainColor}" IsHitTestVisible="True"/>

            <!-- Centred card -->
            <Border Background="{DynamicResource CardBg}"
                    CornerRadius="16"
                    Padding="32,28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="280"
                    MaxWidth="340">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.7"
                                      BlurRadius="28" ShadowDepth="8"
                                      Direction="270"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Large emoji -->
                    <TextBlock Text="{Binding ResultEmoji}"
                               FontFamily="Segoe UI Emoji"
                               FontSize="52"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- Flavour message -->
                    <TextBlock Text="{Binding ResultMessage}"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               LineHeight="22"
                               Margin="0,0,0,16"/>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <!-- Dismiss without restarting -->
                        <Button Content="Close"
                                Command="{Binding DismissResultCommand}"
                                Style="{StaticResource TutSecondaryStyle}"
                                Margin="0,0,10,0"/>

                        <!-- Start a fresh game and close popup -->
                        <Button Content="Play Again 🔄"
                                Command="{Binding NewGameCommand}"
                                Style="{StaticResource TutPrimaryStyle}"/>

                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             LEADERBOARD POPUP — shown on every win
             Phase 1 (IsLeaderboardSubmitted=False): name input + time display
             Phase 2 (IsLeaderboardSubmitted=True):  top-10 table + countdown
        ══════════════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsLeaderboardVisible, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="15">

            <!-- Semi-transparent backdrop -->
            <Rectangle Fill="{DynamicResource CurtainColor}" IsHitTestVisible="True"/>

            <!-- Centred card -->
            <Border Background="{DynamicResource CardBg}"
                    CornerRadius="16"
                    Padding="32,28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="320"
                    MaxWidth="400">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.7"
                                      BlurRadius="28" ShadowDepth="8"
                                      Direction="270"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Win emoji -->
                    <TextBlock Text="{Binding LeaderboardWinEmoji}"
                               FontFamily="Segoe UI Emoji"
                               FontSize="52"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <!-- Win message -->
                    <TextBlock Text="{Binding LeaderboardWinMessage}"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               LineHeight="22"
                               Margin="0,0,0,16"/>

                    <!-- ── Phase 1: Name input (collapsed after submit) ───────── -->
                    <StackPanel Margin="0,0,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLeaderboardSubmitted}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{DynamicResource ChipBorder}" Margin="0,0,0,14"/>

                        <!-- Your time -->
                        <TextBlock Text="{Binding LeaderboardTimeText}"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   Foreground="{DynamicResource LcdFg}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>

                        <!-- Label -->
                        <TextBlock Text="Enter your name for the leaderboard:"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <!-- Name input -->
                        <TextBox x:Name="LeaderboardNameBox"
                                 Text="{Binding LeaderboardNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="30"
                                 FontFamily="Segoe UI"
                                 FontSize="13"
                                 Foreground="{DynamicResource TextPrimary}"
                                 Background="{DynamicResource AppBg}"
                                 BorderBrush="{DynamicResource ChipBorder}"
                                 BorderThickness="1"
                                 Padding="10,7"
                                 CaretBrush="{DynamicResource TextPrimary}"
                                 SelectionBrush="{DynamicResource ChipSelectedBg}"
                                 HorizontalAlignment="Stretch"
                                 Margin="0,0,0,10">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SubmitLeaderboardCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Submit →"
                                    Command="{Binding SubmitLeaderboardCommand}"
                                    Style="{StaticResource TutPrimaryStyle}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Skip"
                                    Command="{Binding CloseLeaderboardCommand}"
                                    Style="{StaticResource TutSecondaryStyle}"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- ── Phase 2: Leaderboard table (visible after submit) ───── -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLeaderboardSubmitted}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{DynamicResource ChipBorder}" Margin="0,0,0,12"/>

                        <!-- Title -->
                        <TextBlock Text="🏆 Leaderboard"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource LcdFg}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>

                        <!-- Header row -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="52"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="#"    FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Name" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="4,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="Time" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Entry rows -->
                        <ItemsControl ItemsSource="{Binding LeaderboardEntries}" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="4,5" Margin="0,2">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHighlight}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource ChipSelectedBg}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="52"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Rank}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="4,0,0,0"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TimeDisplay}"
                                                       FontFamily="Segoe UI"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Countdown -->
                        <TextBlock Text="{Binding LeaderboardCountdownText}"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Close"
                                    Command="{Binding CloseLeaderboardCommand}"
                                    Style="{StaticResource TutSecondaryStyle}"
                                    Margin="0,0,10,0"/>
                            <Button Content="Play Again 🔄"
                                    Command="{Binding PlayAgainFromLeaderboardCommand}"
                                    Style="{StaticResource TutPrimaryStyle}"/>
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             LEADERBOARD BROWSER — per-mode tabs, openable at any time
        ══════════════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsLeaderboardBrowserVisible, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="18">

            <Rectangle Fill="{DynamicResource CurtainColor}" IsHitTestVisible="True"/>

            <Border Background="{DynamicResource CardBg}"
                    CornerRadius="16"
                    Padding="28,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="380"
                    MaxWidth="440">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.7"
                                      BlurRadius="28" ShadowDepth="8" Direction="270"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Title -->
                    <TextBlock Text="🏆 Leaderboard"
                               FontFamily="Segoe UI Emoji"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                    <!-- Tab selector chips -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition/>
                            <ColumnDefinition/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <!-- Easy tab -->
                        <Button Grid.Column="0" Margin="0,0,4,0"
                                Command="{Binding SelectLeaderboardTabCommand}" CommandParameter="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SmallChipStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedLeaderboardTab}" Value="0">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" Padding="10,7">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                              TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                              TextElement.FontWeight="SemiBold"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Easy" FontSize="11"/>
                        </Button>

                        <!-- Medium tab -->
                        <Button Grid.Column="1" Margin="0,0,4,0"
                                Command="{Binding SelectLeaderboardTabCommand}" CommandParameter="1">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SmallChipStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedLeaderboardTab}" Value="1">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" Padding="10,7">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                              TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                              TextElement.FontWeight="SemiBold"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Medium" FontSize="11"/>
                        </Button>

                        <!-- Hard tab -->
                        <Button Grid.Column="2" Margin="0,0,4,0"
                                Command="{Binding SelectLeaderboardTabCommand}" CommandParameter="2">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SmallChipStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedLeaderboardTab}" Value="2">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" Padding="10,7">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                              TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                              TextElement.FontWeight="SemiBold"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Hard" FontSize="11"/>
                        </Button>

                        <!-- Special tab -->
                        <Button Grid.Column="3"
                                Command="{Binding SelectLeaderboardTabCommand}" CommandParameter="3">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SmallChipStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedLeaderboardTab}" Value="3">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{DynamicResource ChipSelectedBg}" CornerRadius="8" Padding="10,7">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                              TextElement.Foreground="{DynamicResource ChipSelectedFg}"
                                                                              TextElement.FontWeight="SemiBold"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Special" FontSize="11"/>
                        </Button>
                    </Grid>

                    <!-- Divider -->
                    <Rectangle Height="1" Fill="{DynamicResource ChipBorder}" Margin="0,0,0,12"/>

                    <!-- ── Shared row header ──────────────────────────────── -->
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="52"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"    FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Name" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="Time" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- ── Easy leaderboard ───────────────────────────────── -->
                    <StackPanel MinHeight="60">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLeaderboardTab}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <!-- World Record row -->
                        <Border Background="#1A8B6914" BorderBrush="#B8860B" BorderThickness="1"
                                CornerRadius="6" Padding="6,5" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="62"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🌍" FontSize="13"
                                           FontFamily="Segoe UI Emoji" HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Kamil Murański &amp; Ze-En Ju" FontSize="12"
                                               FontWeight="Bold" Foreground="#DAA520"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="World Record" FontSize="9" Foreground="#8B6914"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="0.49s" FontSize="12" FontWeight="Bold"
                                           Foreground="#DAA520" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Rectangle Height="1" Fill="{DynamicResource ChipBorder}" Margin="0,0,0,8"/>
                        <TextBlock Text="No records yet" FontSize="12" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasEasyLeaderboard}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding EasyLeaderboard}">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="52"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" Margin="4,0,0,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TimeDisplay}" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ── Medium leaderboard ─────────────────────────────── -->
                    <StackPanel MinHeight="60">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLeaderboardTab}" Value="1">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <!-- World Record row -->
                        <Border Background="#1A8B6914" BorderBrush="#B8860B" BorderThickness="1"
                                CornerRadius="6" Padding="6,5" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="62"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🌍" FontSize="13"
                                           FontFamily="Segoe UI Emoji" HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Kamil Murański" FontSize="12"
                                               FontWeight="Bold" Foreground="#DAA520"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="World Record" FontSize="9" Foreground="#8B6914"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="6.75s" FontSize="12" FontWeight="Bold"
                                           Foreground="#DAA520" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Rectangle Height="1" Fill="{DynamicResource ChipBorder}" Margin="0,0,0,8"/>
                        <TextBlock Text="No records yet" FontSize="12" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasMediumLeaderboard}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding MediumLeaderboard}">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="52"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" Margin="4,0,0,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TimeDisplay}" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ── Hard leaderboard ───────────────────────────────── -->
                    <StackPanel MinHeight="60">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLeaderboardTab}" Value="2">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <!-- World Record row -->
                        <Border Background="#1A8B6914" BorderBrush="#B8860B" BorderThickness="1"
                                CornerRadius="6" Padding="6,5" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="62"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🌍" FontSize="13"
                                           FontFamily="Segoe UI Emoji" HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Ze-En Ju" FontSize="12"
                                               FontWeight="Bold" Foreground="#DAA520"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="World Record" FontSize="9" Foreground="#8B6914"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="27.53s" FontSize="12" FontWeight="Bold"
                                           Foreground="#DAA520" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Rectangle Height="1" Fill="{DynamicResource ChipBorder}" Margin="0,0,0,8"/>
                        <TextBlock Text="No records yet" FontSize="12" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasHardLeaderboard}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding HardLeaderboard}">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="52"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" Margin="4,0,0,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TimeDisplay}" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ── Special leaderboard ────────────────────────────── -->
                    <StackPanel MinHeight="60">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedLeaderboardTab}" Value="3">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="No records yet" FontSize="12" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSpecialLeaderboard}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding SpecialLeaderboard}">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="52"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" Margin="4,0,0,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TimeDisplay}" FontSize="12" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Close button -->
                    <Rectangle Height="1" Fill="{DynamicResource ChipBorder}" Margin="0,12,0,12"/>
                    <Button Content="Close"
                            Command="{Binding CloseLeaderboardBrowserCommand}"
                            Style="{StaticResource TutPrimaryStyle}"
                            HorizontalAlignment="Center"/>

                </StackPanel>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             WORLD RECORD BROKEN — gift-box celebration popup (ZIndex=30)
        ══════════════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsWorldRecordBrokenVisible, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="30">

            <Rectangle Fill="{DynamicResource CurtainColor}" IsHitTestVisible="True"/>

            <Border Background="{DynamicResource CardBg}"
                    CornerRadius="20"
                    Padding="36,30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="440">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.75"
                                      BlurRadius="32" ShadowDepth="10" Direction="270"/>
                </Border.Effect>

                <StackPanel HorizontalAlignment="Center">

                    <!-- ── Phase 1: gift not yet opened ── -->
                    <StackPanel HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGiftOpened}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="🌍 World Record Broken!"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#DAA520"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="You just beat the official world record!"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"
                                   TextAlignment="Center"/>

                        <TextBlock Text="A special prize is waiting for you. Tap the gift to open it!"
                                   FontFamily="Segoe UI"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>

                        <Button x:Name="GiftBoxBtn"
                                Command="{Binding OpenGiftCommand}"
                                HorizontalAlignment="Center"
                                Cursor="Hand"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" Padding="8">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock x:Name="GiftEmoji"
                                       Text="🎁"
                                       FontFamily="Segoe UI Emoji"
                                       FontSize="72"
                                       HorizontalAlignment="Center">
                                <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                                <TextBlock.RenderTransform>
                                    <ScaleTransform x:Name="GiftBoxScale" ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Button>
                    </StackPanel>

                    <!-- ── Phase 2: gift opened ── -->
                    <StackPanel HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGiftOpened}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock x:Name="GiftOpenEmoji"
                                   Text="🎊"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="72"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12">
                            <TextBlock.RenderTransformOrigin>0.5,0.5</TextBlock.RenderTransformOrigin>
                            <TextBlock.RenderTransform>
                                <ScaleTransform x:Name="GiftOpenScale" ScaleX="1" ScaleY="1"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <TextBlock Text="Congratulations! 🎉"
                                   FontFamily="Segoe UI Emoji"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#DAA520"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="You've earned a 1-year Claude Pro subscription!"
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"
                                   TextAlignment="Center"/>

                        <TextBlock FontFamily="Segoe UI"
                                   FontSize="13"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,18"
                                   TextAlignment="Center">
                            <Hyperlink NavigateUri="{Binding WorldRecordPrizeLink}"
                                       RequestNavigate="OnPrizeLinkNavigate"
                                       Foreground="#4FC3F7">
                                Click here to claim your prize →
                            </Hyperlink>
                        </TextBlock>

                    </StackPanel>

                    <!-- Close button (always visible) -->
                    <Rectangle Height="1" Fill="{DynamicResource ChipBorder}" Margin="0,8,0,14"/>
                    <Button Content="Close"
                            Command="{Binding CloseWorldRecordPopupCommand}"
                            Style="{StaticResource TutSecondaryStyle}"
                            HorizontalAlignment="Center"/>

                </StackPanel>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             UNLOCK CONFIRM POPUP
        ══════════════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsUnlockConfirmVisible, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="20">

            <!-- Semi-transparent backdrop -->
            <Rectangle Fill="{DynamicResource CurtainColor}" IsHitTestVisible="True"/>

            <!-- Centred card -->
            <Border Background="{DynamicResource CardBg}"
                    CornerRadius="16"
                    Padding="32,28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="300"
                    MaxWidth="360">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.7"
                                      BlurRadius="28" ShadowDepth="8"
                                      Direction="270"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="🔓"
                               FontFamily="Segoe UI Emoji"
                               FontSize="44"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding UnlockConfirmTitle}"
                               FontFamily="Segoe UI"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding UnlockConfirmBody}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               LineHeight="20"
                               Margin="0,0,0,22"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <Button Content="Cancel"
                                Command="{Binding CancelUnlockCommand}"
                                Style="{StaticResource TutSecondaryStyle}"
                                Margin="0,0,12,0"/>

                        <Button Content="Unlock! 🔓"
                                Command="{Binding ConfirmUnlockCommand}"
                                Style="{StaticResource TutPrimaryStyle}"/>

                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             QUIZ POPUP
        ══════════════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsQuizPopupVisible, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="25">

            <!-- Backdrop -->
            <Rectangle Fill="{DynamicResource CurtainColor}" IsHitTestVisible="True"/>

            <!-- Card -->
            <Border Background="{DynamicResource CardBg}"
                    CornerRadius="16"
                    Padding="28,24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="420">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.7"
                                      BlurRadius="28" ShadowDepth="8" Direction="270"/>
                </Border.Effect>

                <StackPanel>

                    <!-- Title -->
                    <TextBlock Text="🎯 Quiz Time!"
                               FontFamily="Segoe UI"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                    <!-- Rules strip (always visible) -->
                    <Border Background="{DynamicResource AppBg}"
                            CornerRadius="8"
                            Padding="12,9"
                            Margin="0,0,0,16">
                        <TextBlock FontFamily="Segoe UI"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap"
                                   LineHeight="17"
                                   Text="✅ Correct answer → +3 ⭐    ❌ Wrong answer → −1 ⭐    ⏭ Close without answering → 0 (opportunity lost)"/>
                    </Border>

                    <!-- Question text (always visible) -->
                    <TextBlock Text="{Binding QuizQuestionText}"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               TextWrapping="Wrap"
                               LineHeight="20"
                               Margin="0,0,0,14"/>

                    <!-- Answer options (2 × 2 grid — buttons highlight after answering) -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Option 0 -->
                        <Button Grid.Row="0" Grid.Column="0"
                                Command="{Binding AnswerQuizCommand}" CommandParameter="0"
                                Content="{Binding QuizOption0}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource QuizOptionStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding QuizOption0State}" Value="Correct">
                                            <Setter Property="Template" Value="{StaticResource QuizOptionCorrectTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding QuizOption0State}" Value="Wrong">
                                            <Setter Property="Template" Value="{StaticResource QuizOptionWrongTemplate}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Option 1 -->
                        <Button Grid.Row="0" Grid.Column="2"
                                Command="{Binding AnswerQuizCommand}" CommandParameter="1"
                                Content="{Binding QuizOption1}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource QuizOptionStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding QuizOption1State}" Value="Correct">
                                            <Setter Property="Template" Value="{StaticResource QuizOptionCorrectTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding QuizOption1State}" Value="Wrong">
                                            <Setter Property="Template" Value="{StaticResource QuizOptionWrongTemplate}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Option 2 -->
                        <Button Grid.Row="2" Grid.Column="0"
                                Command="{Binding AnswerQuizCommand}" CommandParameter="2"
                                Content="{Binding QuizOption2}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource QuizOptionStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding QuizOption2State}" Value="Correct">
                                            <Setter Property="Template" Value="{StaticResource QuizOptionCorrectTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding QuizOption2State}" Value="Wrong">
                                            <Setter Property="Template" Value="{StaticResource QuizOptionWrongTemplate}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Option 3 -->
                        <Button Grid.Row="2" Grid.Column="2"
                                Command="{Binding AnswerQuizCommand}" CommandParameter="3"
                                Content="{Binding QuizOption3}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource QuizOptionStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding QuizOption3State}" Value="Correct">
                                            <Setter Property="Template" Value="{StaticResource QuizOptionCorrectTemplate}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding QuizOption3State}" Value="Wrong">
                                            <Setter Property="Template" Value="{StaticResource QuizOptionWrongTemplate}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- Result message (shown after answering) -->
                    <TextBlock Text="{Binding QuizResultMessage}"
                               FontFamily="Segoe UI Emoji"
                               FontSize="16"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsQuizAnswered}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding QuizResultIsCorrect}" Value="True">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding QuizResultIsCorrect}" Value="False">
                                        <Setter Property="Foreground" Value="#EF5350"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Single action button: "Skip" before answering, "Close" after -->
                    <Button Content="{Binding QuizCloseButtonText}"
                            Command="{Binding CloseQuizCommand}"
                            HorizontalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TutPrimaryStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsQuizAnswered}" Value="False">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" Padding="4,2">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          TextElement.Foreground="{DynamicResource TextMuted}"
                                                                          TextElement.FontSize="11"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════
             WINDOW CONTROLS — minimize + close, fixed top-right corner
        ══════════════════════════════════════════════════════════════════════ -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,14,14,0"
                    Panel.ZIndex="10">
            <Button Style="{StaticResource MinimizeButtonStyle}"
                    Command="{Binding MinimizeCommand}"
                    Margin="0,0,6,0"
                    Content="—"/>
            <Button Style="{StaticResource CloseButtonStyle}"
                    Command="{Binding RequestCloseCommand}"
                    Content="✕"/>
        </StackPanel>

        <!-- ══════════════════════════════════════════════════════════════════
             EXIT CONFIRM POPUP
        ══════════════════════════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsCloseConfirmVisible, Converter={StaticResource BoolToVis}}"
              Panel.ZIndex="20">

            <!-- Semi-transparent backdrop -->
            <Rectangle Fill="{DynamicResource CurtainColor}" IsHitTestVisible="True"/>

            <!-- Centred card -->
            <Border Background="{DynamicResource CardBg}"
                    CornerRadius="16"
                    Padding="32,28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="260"
                    MaxWidth="320">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.7"
                                      BlurRadius="28" ShadowDepth="8"
                                      Direction="270"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="🚪"
                               FontFamily="Segoe UI Emoji"
                               FontSize="44"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Exit game?"
                               FontFamily="Segoe UI"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Your current progress will be lost."
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Foreground="{DynamicResource TextMuted}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,0,0,22"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <Button Content="Cancel"
                                Command="{Binding CancelCloseCommand}"
                                Style="{StaticResource TutSecondaryStyle}"
                                Margin="0,0,12,0"/>

                        <Button Content="Exit 🚪"
                                Command="{Binding ConfirmCloseCommand}"
                                Style="{StaticResource TutPrimaryStyle}"/>

                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</Window>
