<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Tomorrow Night Blue — deep navy with warm amber accents.
    -->

    <!-- ── Layout / container colours ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="AppBg"          Color="#002451"/>
    <SolidColorBrush x:Key="CardBg"         Color="#00346E"/>

    <!-- ── Cell colours ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CellBg"         Color="#003F8E"/>
    <SolidColorBrush x:Key="CellRevealedBg" Color="#002451"/>
    <SolidColorBrush x:Key="CellBorder"     Color="#0052A5"/>
    <SolidColorBrush x:Key="CellHoverBg"    Color="#004FAF"/>
    <SolidColorBrush x:Key="CellPressedBg"  Color="#001E3D"/>
    <SolidColorBrush x:Key="MineBg"         Color="#4A0010"/>
    <SolidColorBrush x:Key="MineBorder"     Color="#FF9DA1"/>

    <!-- ── LCD digits ────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="LcdFg"          Color="#EBBB67"/>

    <!-- ── Reset / emoji button ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ResetBg"        Color="#003F8E"/>
    <SolidColorBrush x:Key="ResetBorder"    Color="#0052A5"/>
    <SolidColorBrush x:Key="WinBg"          Color="#1A5C2A"/>
    <SolidColorBrush x:Key="WinBorder"      Color="#D1F1A9"/>
    <SolidColorBrush x:Key="LossBg"         Color="#5C1A1A"/>
    <SolidColorBrush x:Key="LossBorder"     Color="#FF9DA1"/>

    <!-- ── Difficulty / theme chips ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ChipBorder"         Color="#0052A5"/>
    <SolidColorBrush x:Key="ChipFg"             Color="#7285B7"/>
    <SolidColorBrush x:Key="ChipHoverBg"        Color="#00346E"/>
    <SolidColorBrush x:Key="ChipHoverFg"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ChipSelectedBg"     Color="#BBDAFF"/>
    <SolidColorBrush x:Key="ChipSelectedFg"     Color="#002451"/>
    <SolidColorBrush x:Key="SpecialChipSelectedBg" Color="#EBBB67"/>

    <!-- ── Typography ────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TitleFg"        Color="#7285B7"/>
    <SolidColorBrush x:Key="TextPrimary"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondary"  Color="#BBDAFF"/>
    <SolidColorBrush x:Key="TextMuted"      Color="#4A5F8A"/>

    <!-- ── Tutorial overlay ──────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CurtainColor"       Color="#D9002451"/>
    <SolidColorBrush x:Key="TutPrimaryBg"       Color="#BBDAFF"/>
    <SolidColorBrush x:Key="TutPrimaryFg"       Color="#002451"/>
    <SolidColorBrush x:Key="TutSecondaryBg"     Color="#003F8E"/>
    <SolidColorBrush x:Key="TutSecondaryFg"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TutSkipFg"          Color="#7285B7"/>
    <SolidColorBrush x:Key="TutSkipHoverBg"     Color="#00346E"/>

    <!-- ── Number colours (1–8) — Tomorrow Night Blue token palette ─────────── -->
    <SolidColorBrush x:Key="Num1" Color="#BBDAFF"/>  <!-- light blue       -->
    <SolidColorBrush x:Key="Num2" Color="#D1F1A9"/>  <!-- light green      -->
    <SolidColorBrush x:Key="Num3" Color="#FF9DA1"/>  <!-- pink / red       -->
    <SolidColorBrush x:Key="Num4" Color="#EBBBFF"/>  <!-- light purple     -->
    <SolidColorBrush x:Key="Num5" Color="#FECA74"/>  <!-- yellow           -->
    <SolidColorBrush x:Key="Num6" Color="#99FFFF"/>  <!-- aqua / cyan      -->
    <SolidColorBrush x:Key="Num7" Color="#FFFFFF"/>  <!-- white            -->
    <SolidColorBrush x:Key="Num8" Color="#7285B7"/>  <!-- muted blue-gray  -->
</ResourceDictionary>
